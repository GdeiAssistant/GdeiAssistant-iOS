"mock.community.topicSummary.techExchange" = "分享开发经验、项目实践与技术活动。";
"mock.community.topicSummary.clubActivity" = "聚合校内社团招新、活动预告与经验交流。";
"mock.community.topicSummary.studyHelp" = "课程答疑、复习资料共享与组队学习。";
"mock.community.topicSummary.courseDiscussion" = "围绕课程内容、作业与考试安排交流。";
"mock.community.topicSummary.campusEvent" = "校园赛事、讲座和线下活动的集中入口。";
"mock.community.topicSummary.volunteer" = "志愿者招募、服务心得和第二课堂资讯。";
"mock.community.topicSummary.studyAbroad" = "交换申请、语言考试与海外学习经验。";
"mock.community.topicSummary.lecture" = "学术讲座、职业分享和专题活动汇总。";
"mock.community.topicSummary.campusLife" = "食堂、宿舍、交通与日常生活信息分享。";
"mock.community.topicSummary.canteen" = "食堂窗口测评、菜单推荐和营业调整。";
"mock.community.topicSummary.announcement" = "校内设施维护、时间变更与官方提醒。";
"mock.community.topicSummary.library" = "馆藏检索、借阅经验和自习空间动态。";
"mock.community.topicSummary.default" = "校园社区话题讨论。";
"mock.community.content.hot1" = "这次分享会会从 SwiftUI 页面组织、项目目录结构、接口层封装三个方面展开，也会结合真实校园产品的迭代经验，聊一聊学生项目如何做出完成度。活动后半段会留出时间做现场答疑，欢迎带着自己的代码和问题来。";
"mock.community.content.hot2" = "最近数据库复习越看越乱，特别是事务隔离级别和关系代数部分，总觉得抓不住重点。想问问大家如果只有一周时间，应该先看教材、PPT 还是历年题？如果有整理好的笔记或者刷题路径，也想借鉴一下。";
"mock.community.content.hot3" = "今年校园马拉松计划扩大路线范围，志愿者需要协助起终点秩序维护、赛道补给和完赛引导。报名后会统一培训，服务时长可计入志愿学分。";
"mock.community.content.latest1" = "今晚英语角会邀请两位刚完成交换申请的学长学姐，重点分享语言成绩准备、文书时间线和院校选择逻辑。欢迎准备四六级后继续冲刺雅思托福的同学来听。";
"mock.community.content.latest2" = "最近北区食堂新开的轻食窗口很火，想看看大家吃过之后的真实评价。尤其想知道鸡胸肉套餐的分量和排队速度，适不适合赶课间隙去买。";
"mock.community.content.latest3" = "前几天很多同学反馈 3 楼插座接触不良，现在馆内维护已经完成。如果后续还有新问题，可以继续在本帖留言，方便集中反馈给图书馆老师。";
"mock.community.content.default" = "这是一条来自校园社区的帖子详情内容，用于展示评论、标签和互动能力。";

